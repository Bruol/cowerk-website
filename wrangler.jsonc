{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "cowerk-website",
	"compatibility_date": "2026-02-15",
	"compatibility_flags": ["nodejs_als", "nodejs_compat"],
	"main": ".svelte-kit/cloudflare/_worker.js",
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"ratelimits": [
		{
			"name": "FORM_RATE_LIMITER",
			"namespace_id": "1001",
			"simple": {
				"limit": 3,
				"period": 60
			}
		}
	],
	"workers_dev": true,
	"preview_urls": true
}
